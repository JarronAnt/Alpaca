# .env.example
# LLM Configuration
OLLAMA_URL=http://localhost:11434/api/chat
ROUTER_MODEL=qwen2.5
PLANNER_MODEL=qwen2.5
BUILDER_MODEL=qwen2.5
TESTER_MODEL=qwen2.5
REVIEWER_MODEL=qwen2.5

# Application
LOG_LEVEL=INFO
DEBUG=false
WORKSPACE_ROOT=~/Desktop/AgentWorkspace

# Limits
MAX_HISTORY=20
MAX_TOOL_STEPS=25
LLM_TIMEOUT=120
SHELL_TIMEOUT=60

